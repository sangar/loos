#!/bin/bash
# loOS Background Manager
# Handles wallpaper and terminal background settings

set -u

# Paths
CONFIG_DIR="${HOME}/.config"
LOOS_CONFIG="${CONFIG_DIR}/loos"
WALLPAPER_DIR="${HOME}/.local/share/loos/wallpapers"
CURRENT_WALLPAPER_FILE="${LOOS_CONFIG}/current-wallpaper"
BACKGROUND_CONFIG="${LOOS_CONFIG}/background.conf"

# Default config
BACKGROUND_MODE="solid"  # solid, transparent, blur
BACKGROUND_OPACITY="0.8"
BACKGROUND_COLOR=""

# Load existing config if present
load_config() {
    if [[ -f "$BACKGROUND_CONFIG" ]]; then
        source "$BACKGROUND_CONFIG"
    fi
}

# Save config
save_config() {
    cat > "$BACKGROUND_CONFIG" << EOF
# loOS Background Configuration
# Generated by loos-background

BACKGROUND_MODE="$BACKGROUND_MODE"
BACKGROUND_OPACITY="$BACKGROUND_OPACITY"
BACKGROUND_COLOR="$BACKGROUND_COLOR"
EOF
}

# Get current theme background color
get_theme_bg_color() {
    local theme_file="${LOOS_CONFIG}/current-theme"
    if [[ -f "$theme_file" ]]; then
        local theme
        theme=$(cat "$theme_file")
        # Source color definitions to get BG
        local color_file="${HOME}/.local/share/loos/config/themes/colors/${theme}.sh"
        if [[ -f "$color_file" ]]; then
            # Extract BG value
            grep "^BG=" "$color_file" | cut -d'"' -f2
            return
        fi
    fi
    # Default fallback
    echo "1e1e2e"
}

# Apply background to foot terminal
apply_foot_background() {
    local foot_config="${CONFIG_DIR}/foot/foot.ini"
    
    if [[ ! -f "$foot_config" ]]; then
        echo "Error: foot config not found" >&2
        return 1
    fi
    
    # Backup
    cp "$foot_config" "$foot_config.bak"
    
    # Remove existing alpha/background settings
    sed -i '/^background=/d' "$foot_config"
    sed -i '/^alpha=/d' "$foot_config"
    
    case "$BACKGROUND_MODE" in
        transparent)
            # Add alpha setting for transparency
            # Keep background color but make it transparent
            local bg_color
            if [[ -n "$BACKGROUND_COLOR" ]]; then
                bg_color="$BACKGROUND_COLOR"
            else
                bg_color=$(get_theme_bg_color)
            fi
            
            # Add to config
            sed -i "/^\[colors/a\\
alpha=$BACKGROUND_OPACITY" "$foot_config"
            ;;
        blur)
            # For blur effect, we'd need compositor settings
            # For now, just set semi-transparent
            sed -i "/^\[colors/a\\
alpha=$BACKGROUND_OPACITY" "$foot_config"
            echo "Note: Full blur effect requires compositor configuration"
            ;;
        solid|*)
            # Solid background - colors are already set in theme
            # Just ensure no alpha is set
            ;;
    esac
    
    echo "Applied $BACKGROUND_MODE background to foot"
}

# Set solid background with specific color
set_solid_background() {
    local color="${1:-}"
    
    if [[ -z "$color" ]]; then
        # Use theme color
        color=$(get_theme_bg_color)
    fi
    
    BACKGROUND_MODE="solid"
    BACKGROUND_COLOR="$color"
    save_config
    apply_foot_background
    
    echo "Set solid background: #$color"
}

# Set transparent background
set_transparent_background() {
    local opacity="${1:-0.8}"
    
    # Validate opacity (0.0 - 1.0)
    if ! [[ "$opacity" =~ ^0\.[0-9]+$ ]] && ! [[ "$opacity" =~ ^1\.0$ ]]; then
        echo "Invalid opacity: $opacity (use 0.0 - 1.0)" >&2
        return 1
    fi
    
    BACKGROUND_MODE="transparent"
    BACKGROUND_OPACITY="$opacity"
    save_config
    apply_foot_background
    
    echo "Set transparent background: ${opacity} opacity"
}

# Show current background settings
show_current() {
    load_config
    
    echo "Current Background Settings:"
    echo "============================"
    echo "Mode: $BACKGROUND_MODE"
    
    if [[ "$BACKGROUND_MODE" == "transparent" ]] || [[ "$BACKGROUND_MODE" == "blur" ]]; then
        echo "Opacity: $BACKGROUND_OPACITY"
    fi
    
    if [[ -n "$BACKGROUND_COLOR" ]]; then
        echo "Custom Color: #$BACKGROUND_COLOR"
    else
        echo "Color: Theme default (#$(get_theme_bg_color))"
    fi
    
    # Show wallpaper info
    echo ""
    echo "Wallpaper:"
    if [[ -f "$CURRENT_WALLPAPER_FILE" ]]; then
        cat "$CURRENT_WALLPAPER_FILE"
    else
        echo "  Not set (random on startup)"
    fi
}

# Quick preset commands
apply_preset() {
    local preset="$1"
    
    case "$preset" in
        solid)
            set_solid_background
            ;;
        transparent|trans)
            set_transparent_background "0.85"
            ;;
        glass|blur)
            set_transparent_background "0.7"
            echo "For full glass effect, also configure Hyprland blur settings"
            ;;
        *)
            echo "Unknown preset: $preset" >&2
            echo "Available: solid, transparent, glass" >&2
            return 1
            ;;
    esac
}

# Main command handler
case "${1:-}" in
    solid)
        set_solid_background "${2:-}"
        ;;
    transparent|trans)
        set_transparent_background "${2:-0.8}"
        ;;
    blur|glass)
        set_transparent_background "${2:-0.7}"
        ;;
    preset|p)
        if [[ -z "${2:-}" ]]; then
            echo "Usage: loos-background preset <solid|transparent|glass>"
            exit 1
        fi
        apply_preset "$2"
        ;;
    show|s|current|c)
        show_current
        ;;
    apply)
        # Re-apply current settings
        load_config
        apply_foot_background
        echo "Re-applied background settings"
        ;;
    help|h|--help|-h|*)
        cat << 'EOF'
loOS Background Manager

Manage terminal and desktop background settings.

Usage:
  loos-background solid [color]      - Set solid background (hex color optional)
  loos-background transparent [0.x] - Set transparent background (opacity 0.0-1.0)
  loos-background blur [0.x]       - Set blur/glass effect (requires compositor)
  loos-background preset <name>    - Quick preset: solid, transparent, glass
  
  loos-background show             - Show current settings
  loos-background apply            - Re-apply current settings
  loos-background help             - Show this help

Examples:
  loos-background solid              # Use theme's solid color
  loos-background solid 282828       # Custom dark gray
  loos-background transparent 0.9  # Slight transparency
  loos-background preset glass       # Quick glass effect preset

Notes:
  - Transparency requires a compositor (Hyprland has built-in compositing)
  - For blur effects, configure Hyprland's blur settings separately
  - Settings persist across sessions
  - Wallpaper is managed separately with: loos-wallpaper

EOF
        ;;
esac
