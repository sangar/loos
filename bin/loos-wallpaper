#!/bin/bash
# loOS Wallpaper Manager
# Simple wallpaper selection and management using rofi and hyprpaper

set -u

WALLPAPER_DIR="${HOME}/.local/share/loos/wallpapers"
CACHE_DIR="${HOME}/.cache/loos/wallpapers"
CURRENT_WALLPAPER_FILE="${HOME}/.config/loos/current-wallpaper"

# Ensure directories exist
mkdir -p "$WALLPAPER_DIR" "$CACHE_DIR"

# Function to generate thumbnails
generate_thumbnails() {
    echo "Generating thumbnails..."
    for img in "$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp}; do
        [ -f "$img" ] || continue
        local basename=$(basename "$img")
        local thumb="$CACHE_DIR/thumb_$basename"
        if [[ ! -f "$thumb" ]]; then
            magick "$img" -resize 300x300^ -gravity center -extent 300x300 "$thumb" 2>/dev/null || \
            cp "$img" "$thumb"
        fi
    done
}

# Function to list wallpapers
list_wallpapers() {
    for img in "$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp}; do
        [ -f "$img" ] || continue
        local basename=$(basename "$img")
        local thumb="$CACHE_DIR/thumb_$basename"
        # Output format for rofi with icon: name\0icon\x1fpath
        printf "%s\0icon\x1f%s\n" "$basename" "$thumb"
    done
}

# Function to set wallpaper
set_wallpaper() {
    local wallpaper="$1"
    local full_path="$WALLPAPER_DIR/$wallpaper"
    
    if [[ ! -f "$full_path" ]]; then
        echo "Error: Wallpaper not found: $full_path" >&2
        return 1
    fi
    
    # Save current wallpaper
    echo "$full_path" > "$CURRENT_WALLPAPER_FILE"
    
    # Set with hyprpaper
    hyprctl hyprpaper preload "$full_path" 2>/dev/null || true
    hyprctl hyprpaper wallpaper ", $full_path" 2>/dev/null || true
    
    echo "Wallpaper set: $wallpaper"
    
    # Send notification
    if command -v notify-send &>/dev/null; then
        notify-send -a "loOS" -i "$full_path" "Wallpaper Changed" "$wallpaper"
    fi
}

# Function to select wallpaper via rofi
select_wallpaper() {
    generate_thumbnails
    
    local selected
    selected=$(list_wallpapers | rofi -dmenu -i \
        -p "Select Wallpaper" \
        -theme "${HOME}/.config/rofi/wallpaper.rasi" \
        -show-icons \
        -config "${HOME}/.config/rofi/theme.rasi" 2>/dev/null)
    
    if [[ -n "$selected" ]]; then
        set_wallpaper "$selected"
    fi
}

# Function to set random wallpaper
random_wallpaper() {
    local wallpapers=()
    for img in "$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp}; do
        [ -f "$img" ] || continue
        wallpapers+=("$(basename "$img")")
    done
    
    if [[ ${#wallpapers[@]} -eq 0 ]]; then
        echo "No wallpapers found in $WALLPAPER_DIR" >&2
        return 1
    fi
    
    local random_index=$((RANDOM % ${#wallpapers[@]}))
    set_wallpaper "${wallpapers[$random_index]}"
}

# Function to initialize hyprpaper
case "${1:-}" in
    select|s)
        select_wallpaper
        ;;
    set)
        if [[ -z "${2:-}" ]]; then
            echo "Usage: loos-wallpaper set <wallpaper_name>"
            exit 1
        fi
        set_wallpaper "$2"
        ;;
    random|r)
        random_wallpaper
        ;;
    init|i)
        # Initialize wallpaper on startup
        if [[ -f "$CURRENT_WALLPAPER_FILE" ]]; then
            local saved_wallpaper
            saved_wallpaper=$(cat "$CURRENT_WALLPAPER_FILE")
            # Check if the saved wallpaper still exists
            if [[ -f "$saved_wallpaper" ]]; then
                # Apply directly using full path
                local wallpaper_name
                wallpaper_name=$(basename "$saved_wallpaper")
                set_wallpaper "$wallpaper_name"
            else
                echo "Saved wallpaper not found: $saved_wallpaper" >&2
                echo "Selecting random wallpaper..." >&2
                random_wallpaper
            fi
        else
            echo "No wallpaper configured, selecting random..." >&2
            random_wallpaper
        fi
        ;;
    list|l)
        echo "Available wallpapers:"
        for img in "$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp}; do
            [ -f "$img" ] || continue
            echo "  - $(basename "$img")"
        done
        ;;
    help|h|--help|-h|*)
        cat << 'EOF'
loOS Wallpaper Manager

Usage:
  loos-wallpaper select     - Select wallpaper via rofi
  loos-wallpaper set <name> - Set specific wallpaper
  loos-wallpaper random     - Set random wallpaper
  loos-wallpaper init       - Initialize wallpaper (for autostart)
  loos-wallpaper list       - List available wallpapers
  loos-wallpaper help       - Show this help

Wallpaper directory: ~/.local/share/loos/wallpapers/
EOF
        ;;
esac
