#!/bin/bash

# Add the named packages to the system if they're missing. Returns false if it couldn't be done.

# Refresh sudo credentials before package operations
sudo -v 2>/dev/null || true

# Update mirrorlist to use a reliable mirror first
echo "Ensuring mirrors are up to date..."
sudo pacman -Syy --noconfirm &>/dev/null || true

# Check for cached packages
CACHED_COUNT=0
for pkg in "$@"; do
  if ls /var/cache/pacman/pkg/${pkg}-* 1>/dev/null 2>&1; then
    ((CACHED_COUNT++))
  fi
done

if [[ $CACHED_COUNT -gt 0 ]] && [[ $CACHED_COUNT -eq $# ]]; then
  echo "All packages found in cache (/var/cache/pacman/pkg/)"
fi

# Try to install requested packages
if loos-pkg-missing "$@"; then
  echo "Installing packages: $@"
  # Use --overwrite to handle version mismatches from stale mirrors
  if ! sudo pacman -S --noconfirm --needed --overwrite '*' "$@" 2>&1; then
    echo -e "\033[33mPackage install failed. Updating system and retrying...\033[0m" >&2
    # If install fails, try updating keyring first then system
    sudo pacman -S --noconfirm archlinux-keyring &>/dev/null || true
    # Attempt install again
    sudo pacman -S --noconfirm --needed --overwrite '*' "$@" || exit 1
  fi
fi

for pkg in "$@"; do
  # Secondary check to handle states where pacman doesn't actually register an error
  if ! pacman -Q "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
