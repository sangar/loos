#!/bin/bash
# loOS Theme Manager
# Simple theme management for terminal, rofi, and waybar colors

set -u

# Paths
THEME_DIR="${HOME}/.local/share/loos/themes"
CURRENT_THEME_FILE="${HOME}/.config/loos/current-theme"
CONFIG_DIR="${HOME}/.config"
LOOS_PATH="${LOOS_PATH:-${HOME}/.local/share/loos}"

# Theme definitions (name and description)
declare -A THEMES=(
    ["catppuccin-mocha"]="Catppuccin Mocha - Dark purple theme (default)"
    ["catppuccin-latte"]="Catppuccin Latte - Light theme"
    ["nord"]="Nord - Arctic blue theme"
    ["gruvbox-dark"]="Gruvbox Dark - Retro theme"
    ["onedark"]="One Dark - Atom editor theme"
)

# Source color definitions for a theme
source_theme_colors() {
    local theme="$1"
    local color_file="$LOOS_PATH/config/themes/colors/${theme}.sh"
    
    if [[ -f "$color_file" ]]; then
        source "$color_file"
    else
        echo "Warning: Color definition not found: $color_file" >&2
        return 1
    fi
}

# Function to apply theme to foot terminal
apply_foot_theme() {
    local theme="$1"
    local foot_config="$CONFIG_DIR/foot/foot.ini"
    local theme_file="$LOOS_PATH/config/foot/themes/${theme}.ini"
    local base_file="$LOOS_PATH/config/foot/themes/base.ini"
    
    # Check if theme file exists
    if [[ ! -f "$theme_file" ]]; then
        echo "Error: Foot theme not found: $theme_file" >&2
        return 1
    fi
    
    # Backup original
    [[ -f "$foot_config" ]] && cp "$foot_config" "$foot_config.bak"
    
    # Build config from base + theme colors
    {
        # Copy base config (font, keybindings)
        cat "$base_file"
        echo ""
        # Copy theme colors
        cat "$theme_file"
    } > "$foot_config"
    
    echo "Applied $theme to foot terminal"
}

# Function to apply theme to rofi
apply_rofi_theme() {
    local theme="$1"
    local rofi_config="$CONFIG_DIR/rofi/theme.rasi"
    local theme_file="$LOOS_PATH/config/rofi/themes/${theme}.rasi"
    
    # Check if theme file exists
    if [[ ! -f "$theme_file" ]]; then
        echo "Error: Rofi theme not found: $theme_file" >&2
        return 1
    fi
    
    # Backup original
    [[ -f "$rofi_config" ]] && cp "$rofi_config" "$rofi_config.bak"
    
    # Copy theme file
    cp "$theme_file" "$rofi_config"
    
    echo "Applied $theme to rofi"
}

# Function to apply theme to waybar
apply_waybar_theme() {
    local theme="$1"
    local waybar_style="$CONFIG_DIR/waybar/style.css"
    local theme_file="$LOOS_PATH/config/waybar/themes/${theme}.css"
    
    # Check if theme file exists
    if [[ ! -f "$theme_file" ]]; then
        echo "Error: Waybar theme not found: $theme_file" >&2
        return 1
    fi
    
    # Backup original
    [[ -f "$waybar_style" ]] && cp "$waybar_style" "$waybar_style.bak"
    
    # Copy theme file
    cp "$theme_file" "$waybar_style"
    
    # Reload waybar
    if pgrep waybar &>/dev/null; then
        pkill waybar
        waybar &
    fi
    
    echo "Applied $theme to waybar"
}

# Function to select theme via rofi
select_theme() {
    local theme_list=""
    for theme in "${!THEMES[@]}"; do
        theme_list+="$theme - ${THEMES[$theme]}\n"
    done
    
    local selected
    selected=$(echo -e "$theme_list" | rofi -dmenu -i \
        -p "Select Theme" \
        -config "${HOME}/.config/rofi/theme.rasi" 2>/dev/null | cut -d' ' -f1)
    
    if [[ -n "$selected" ]]; then
        apply_theme "$selected"
    fi
}

# Function to apply complete theme
apply_theme() {
    local theme="$1"
    
    if [[ -z "${THEMES[$theme]:-}" ]]; then
        echo "Unknown theme: $theme" >&2
        echo "Available themes: ${!THEMES[*]}" >&2
        return 1
    fi
    
    # Save current theme
    echo "$theme" > "$CURRENT_THEME_FILE"
    
    # Apply to each component
    apply_foot_theme "$theme"
    apply_rofi_theme "$theme"
    apply_waybar_theme "$theme"
    
    # Send notification
    if command -v notify-send &>/dev/null; then
        notify-send -a "loOS" "Theme Applied" "Applied theme: ${THEMES[$theme]}"
    fi
    
    echo "Theme applied: ${THEMES[$theme]}"
    echo "Note: Some changes may require restarting applications"
}

# Function to list available themes
list_themes() {
    echo "Available themes:"
    for theme in "${!THEMES[@]}"; do
        local status=""
        if [[ -f "$CURRENT_THEME_FILE" ]] && [[ "$(cat "$CURRENT_THEME_FILE")" == "$theme" ]]; then
            status=" [current]"
        fi
        echo "  - $theme - ${THEMES[$theme]}$status"
    done
}

# Function to show current theme
current_theme() {
    if [[ -f "$CURRENT_THEME_FILE" ]]; then
        local current
        current=$(cat "$CURRENT_THEME_FILE")
        echo "Current theme: $current - ${THEMES[$current]:-Unknown}"
    else
        echo "No theme currently set (using defaults)"
    fi
}

# Function to show theme info
theme_info() {
    local theme="${1:-}"
    
    if [[ -z "$theme" ]]; then
        echo "Usage: loos-theme info <theme_name>"
        echo ""
        list_themes
        return 0
    fi
    
    if [[ -z "${THEMES[$theme]:-}" ]]; then
        echo "Unknown theme: $theme" >&2
        return 1
    fi
    
    echo "Theme: $theme"
    echo "Description: ${THEMES[$theme]}"
    echo ""
    
    # Source color definitions
    local color_file="$LOOS_PATH/config/themes/colors/${theme}.sh"
    if [[ -f "$color_file" ]]; then
        echo "Color definitions:"
        grep -E "^(BG|FG|SURFACE|ACCENT|THEME)=" "$color_file" | while read -r line; do
            local var=${line%%=*}
            local val=${line#*=}
            val=${val//\"}
            echo "  $var: $val"
        done
        echo ""
        echo "Files:"
        echo "  Foot:   config/foot/themes/${theme}.ini"
        echo "  Rofi:   config/rofi/themes/${theme}.rasi"
        echo "  Waybar: config/waybar/themes/${theme}.css"
    else
        echo "Color definitions not found"
    fi
}

# Main case statement
case "${1:-}" in
    select|s)
        select_theme
        ;;
    apply|a)
        if [[ -z "${2:-}" ]]; then
            echo "Usage: loos-theme apply <theme_name>"
            list_themes
            exit 1
        fi
        apply_theme "$2"
        ;;
    list|l)
        list_themes
        ;;
    current|c)
        current_theme
        ;;
    info|i)
        theme_info "${2:-}"
        ;;
    help|h|--help|-h|*)
        cat << 'EOF'
loOS Theme Manager

Usage:
  loos-theme select          - Select theme via rofi
  loos-theme apply <name>    - Apply specific theme
  loos-theme list            - List available themes
  loos-theme current         - Show current theme
  loos-theme info <name>     - Show theme details
  loos-theme help            - Show this help

Available themes:
  catppuccin-mocha   - Catppuccin Mocha (dark purple) - default
  catppuccin-latte   - Catppuccin Latte (light)
  nord               - Nord (arctic blue)
  gruvbox-dark       - Gruvbox Dark (retro)
  onedark            - One Dark (Atom)

Applied to: foot, rofi, waybar

Theme files location:
  ~/.local/share/loos/config/themes/colors/     - Color definitions
  ~/.local/share/loos/config/foot/themes/      - Terminal themes
  ~/.local/share/loos/config/rofi/themes/     - Launcher themes
  ~/.local/share/loos/config/waybar/themes/    - Status bar themes

EOF
        ;;
esac
