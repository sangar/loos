#!/bin/bash
# Detect vconsole keyboard layout and update Hyprland config to match
# Creates/updates user-input.conf which overrides system defaults

USER_INPUT_CONF="${HOME}/.config/hypr/user-input.conf"
LOOS_DEFAULT_INPUT="${HOME}/.local/share/loos/default/hypr/input.conf"

# Get keyboard layout from vconsole
VCONSOLE_LAYOUT=$(localectl status 2>/dev/null | grep "VC Keymap" | awk '{print $3}')

# If localectl doesn't work, try reading vconsole.conf directly
if [[ -z "$VCONSOLE_LAYOUT" ]] && [[ -f /etc/vconsole.conf ]]; then
  VCONSOLE_LAYOUT=$(grep "^KEYMAP=" /etc/vconsole.conf 2>/dev/null | cut -d= -f2 | tr -d '"' | cut -d'-' -f1)
fi

# Fallback to US if we can't detect
if [[ -z "$VCONSOLE_LAYOUT" ]]; then
  echo "Warning: Could not detect keyboard layout from vconsole. Checking current locale..." >&2
  VCONSOLE_LAYOUT=$(echo "$LANG" | cut -d_ -f2 | cut -d. -f1 | tr '[:upper:]' '[:lower:]')
  if [[ -z "$VCONSOLE_LAYOUT" ]] || [[ "$VCONSOLE_LAYOUT" == "utf" ]]; then
    VCONSOLE_LAYOUT="us"
  fi
fi

echo "Detected keyboard layout: $VCONSOLE_LAYOUT"

# Ensure hypr config directory exists
mkdir -p "${HOME}/.config/hypr"

# Create user-input.conf with detected layout (overrides system default)
cat > "$USER_INPUT_CONF" <<EOF
# User input configuration - generated by loos-keyboard-sync
# Detected from system vconsole/locale: ${VCONSOLE_LAYOUT}
# This file overrides the system default input settings

input {
    kb_layout = ${VCONSOLE_LAYOUT}
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1
    sensitivity = 0

    touchpad {
        natural_scroll = false
    }
}

env = XCURSOR_SIZE,24
env = HYPRCURSOR_SIZE,24
EOF

echo "Created ${USER_INPUT_CONF} with keyboard layout: ${VCONSOLE_LAYOUT}"

# Also update the default input.conf for consistency
if [[ -f "$LOOS_DEFAULT_INPUT" ]]; then
  # Update the kb_layout line in default input.conf too
  sed -i "s/^[[:space:]]*kb_layout[[:space:]]*=.*/    kb_layout = ${VCONSOLE_LAYOUT}/" "$LOOS_DEFAULT_INPUT"
  echo "Updated ${LOOS_DEFAULT_INPUT} with keyboard layout: ${VCONSOLE_LAYOUT}"
fi
