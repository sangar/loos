#!/bin/bash
# Debug waybar - run manually to see errors

echo "=== Waybar Debug Script ==="
echo ""

# Check if waybar is installed
if ! command -v waybar &>/dev/null; then
  echo "ERROR: waybar not found! Install with: sudo pacman -S waybar"
  exit 1
fi
echo "✓ waybar binary found at: $(which waybar)"

# Check config exists
if [ ! -f "$HOME/.config/waybar/config" ]; then
  echo "ERROR: waybar config not found at ~/.config/waybar/config"
  echo "Run install script to copy configs: bash ~/.local/share/loos/install.sh"
  exit 1
fi
echo "✓ waybar config found"

# Validate JSON
if ! python3 -c "import json; json.load(open('$HOME/.config/waybar/config'))" 2>/dev/null; then
  echo "ERROR: waybar config is not valid JSON!"
  exit 1
fi
echo "✓ waybar config is valid JSON"

# Check CSS exists
if [ ! -f "$HOME/.config/waybar/style.css" ]; then
  echo "WARNING: waybar style.css not found"
fi

echo ""
echo "=== Running waybar with logging ==="
echo "(Press Ctrl+C to exit)"
echo ""

waybar -c "$HOME/.config/waybar/config" -s "$HOME/.config/waybar/style.css" 2>&1
