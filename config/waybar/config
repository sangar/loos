{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "battery", "tray"],

    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "≤░Οβ",
            "2": "≤░Ογ",
            "3": "≤░Οδ",
            "4": "≤░Οε",
            "5": "≤░Οζ",
            "6": "≤░Οη",
            "7": "≤░Οθ",
            "8": "≤░Οι",
            "9": "≤░Οκ",
            "focused": "≤░Οβ",
            "default": "≤░Οβ"
        }
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "separate-outputs": true
    },

    "clock": {
        "format": "{:%Y-%m-%d %H:%M}",
        "format-alt": "{:%A, %B %d, %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "≤░ζθ",
        "format-muted": "≤░ζθ",
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "hands-free": "≤░ΜΜ",
            "headset": "≤░ΜΜ",
            "phone": "≤░ΠΙ",
            "portable": "≤░ΠΙ",
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
        },
        "on-click": "pavucontrol"
    },

    "network": {
        "format-wifi": "≤░νρ {signalStrength}%",
        "format-ethernet": "≤░ΙΑ {ipaddr}",
        "format-disconnected": "≤░νφ",
        "format-alt": "{ifname}: {ipaddr}",
        "tooltip-format": "{ifname} via {gwaddr}"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-plugged": "≤░ΓΕ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
    },

    "tray": {
        "spacing": 10
    }
}
